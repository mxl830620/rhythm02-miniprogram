/* 设置页 v0.7 — 移除声音摇摆/联动反馈 */
.page {
  padding: 24rpx 28rpx 160rpx;
  display: flex; flex-direction: column; gap: 20rpx;
}

/* 卡片 */
.card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  border: 1rpx solid var(--border);
}
.card-head {
  font-size: 28rpx; font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  display: flex; align-items: center; justify-content: space-between;
}
.hint {
  font-size: 22rpx; color: var(--text-tertiary); font-weight: 500;
}

/* 表单行 */
.form-row { margin-bottom: 20rpx; }
.form-row:last-child { margin-bottom: 0; }
.form-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 14rpx;
}

/* chip 选择 */
.chip-row { display: flex; flex-wrap: wrap; gap: 12rpx; }
.chip {
  padding: 18rpx 28rpx;
  border-radius: var(--radius-pill);
  background: rgba(255,255,255,0.07);
  border: 1rpx solid rgba(255,255,255,0.08);
  font-size: 26rpx; font-weight: 600;
  color: var(--text-secondary);
  min-height: 72rpx;
  display: flex; align-items: center;
}
.chip.on {
  background: var(--accent-dim);
  border-color: var(--border-focus);
  color: var(--accent);
}

/* 重音按钮 */
.accent-row { display: flex; gap: 14rpx; flex-wrap: wrap; }
.accent-btn {
  width: 88rpx; height: 88rpx; border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: 700;
  border: 2rpx solid rgba(255,255,255,0.14);
  background: rgba(255,255,255,0.06);
  color: var(--text-secondary);
}
.accent-btn.accent {
  background: var(--danger);
  color: #fff;
  border-color: var(--danger);
}
.accent-btn.normal {
  background: rgba(126,216,255,0.16);
  border-color: rgba(126,216,255,0.40);
  color: var(--accent);
}
.accent-btn.mute {
  background: rgba(255,255,255,0.05);
  color: var(--text-disabled);
  border-color: rgba(255,255,255,0.06);
}

/* 图例 */
.legend {
  display: flex; gap: 28rpx;
  margin-top: 18rpx;
  font-size: 22rpx; color: var(--text-tertiary);
  align-items: center;
}
.leg-dot {
  width: 16rpx; height: 16rpx; border-radius: 4rpx;
  display: inline-block; margin-right: 8rpx; vertical-align: middle;
}
.leg-dot.a { background: var(--danger); }
.leg-dot.n { background: var(--accent); }
.leg-dot.m { background: rgba(255,255,255,0.16); }

.bottom-spacer { height: 20rpx; }
