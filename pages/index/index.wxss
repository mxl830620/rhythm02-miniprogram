/* ====== 节拍器首页 v1.4 ====== */
.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 0;
  padding-bottom: env(safe-area-inset-bottom, 0);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  background: linear-gradient(180deg, #0b1322 0%, #0f172a 40%, #0f172a 100%);
  box-sizing: border-box;
}

/* ---- 顶部信息栏 ---- */
.top-bar {
  width: 100%;
  display: flex; align-items: center; gap: 12rpx;
  padding-bottom: 4rpx;
}
.status-dot {
  width: 14rpx; height: 14rpx; border-radius: 50%;
  background: rgba(255,255,255,0.20);
  transition: background 0.3s;
}
.status-dot.on {
  background: var(--play);
  box-shadow: 0 0 12rpx rgba(34,197,94,0.5);
}
.meter-tag, .unit-tag {
  font-size: 24rpx; font-weight: 600;
}
.meter-tag { color: var(--text-secondary); }
.unit-tag {
  color: var(--accent);
  padding: 4rpx 16rpx;
  background: var(--accent-dim);
  border-radius: var(--radius-pill);
}
.settings-toggle {
  margin-left: auto;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 2rpx;
  padding: 8rpx 18rpx;
  border-radius: var(--radius-md);
  background: rgba(255,255,255,0.08);
  border: 1rpx solid var(--border);
  transition: all 0.25s;
}
.gear-icon {
  font-size: 32rpx;
  line-height: 1;
  color: var(--text-secondary);
}
.gear-label {
  font-size: 18rpx; font-weight: 600;
  color: var(--text-tertiary);
}
.settings-toggle:active { background: rgba(255,255,255,0.15); }

/* ========================================
   仿真节拍器舞台
   ======================================== */
.metro-stage {
  position: relative;
  width: 480rpx;
  height: 650rpx;
  margin: 4rpx auto 0;
}

/* ---- 梯形外壳轮廓（金黄色描边） ---- */
.metro-outline {
  position: absolute;
  bottom: 60rpx; left: 50%;
  transform: translateX(-50%);
  width: 0; height: 0;
  border-bottom: 480rpx solid rgba(130, 217, 255, 0.72);
  border-left: 124rpx solid transparent;
  border-right: 124rpx solid transparent;
  border-radius: 0 0 36rpx 36rpx;
  z-index: 0;
}

/* ---- 梯形外壳主体（蓝灰渐变） ---- */
.metro-body {
  position: absolute;
  bottom: 64rpx; left: 50%;
  transform: translateX(-50%);
  width: 0; height: 0;
  border-bottom: 464rpx solid #435e9c;
  border-left: 116rpx solid transparent;
  border-right: 116rpx solid transparent;
  border-radius: 0 0 32rpx 32rpx;
  z-index: 1;
}

/* ---- 木质纹理 ---- */
.wood-grain {
  position: absolute;
  top: 80rpx; bottom: 170rpx; left: 132rpx; right: 132rpx;
  z-index: 2;
  pointer-events: none;
  background: repeating-linear-gradient(
    84deg,
    transparent,
    transparent 18rpx,
    rgba(214, 234, 255, 0.035) 18rpx,
    rgba(214, 234, 255, 0.035) 20rpx,
    transparent 20rpx
  );
  opacity: 0.9;
}

/* ---- 玻璃反光 ---- */
.glass-cover {
  position: absolute;
  top: 98rpx; bottom: 194rpx; left: 144rpx; right: 144rpx;
  z-index: 5;
  pointer-events: none;
  opacity: 0.40;
  background: linear-gradient(
    115deg,
    transparent 0 30%,
    rgba(210, 243, 255, 0.24) 33%,
    rgba(255, 255, 255, 0.08) 40%,
    transparent 44%
  );
  border: 1rpx solid rgba(204, 238, 255, 0.10);
  border-radius: 4rpx;
}

/* ---- 品牌铭牌 ---- */
.brand-plate {
  position: absolute;
  left: 50%;
  bottom: 152rpx;
  transform: translateX(-50%);
  z-index: 7;
  padding: 6rpx 24rpx;
  border: 1rpx solid rgba(169, 195, 255, 0.30);
  border-radius: 999rpx;
  background: rgba(37, 52, 96, 0.68);
  color: rgba(218, 234, 255, 0.68);
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 3rpx;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.14),
    0 4rpx 8rpx rgba(0, 0, 0, 0.18);
}

/* ---- 刻度尺（右侧） ---- */
.metro-scale {
  position: absolute;
  top: 106rpx; bottom: 226rpx;
  right: 70rpx;
  display: flex;
  flex-direction: column-reverse;
  justify-content: space-between;
  z-index: 6;
  font-size: 20rpx;
  font-weight: 800;
}
.scale-item {
  display: flex; align-items: center; gap: 8rpx;
  color: rgba(196, 211, 245, 0.52);
}
.scale-dash {
  width: 18rpx; height: 4rpx;
  background: rgba(196, 211, 245, 0.32);
}

/* ---- 发条旋钮 ---- */
.winder {
  position: absolute;
  right: 60rpx; bottom: 158rpx;
  width: 50rpx; height: 50rpx;
  z-index: 7;
  border: 4rpx solid rgba(29, 15, 10, 0.8);
  border-radius: 50%;
  background:
    radial-gradient(circle at 35% 32%, rgba(255, 247, 213, 0.36), transparent 22%),
    linear-gradient(0deg, #d6a54b 25%, #81511c 25%, #81511c 50%, #d6a54b 50%, #d6a54b 75%, #81511c 75%);
  box-shadow:
    inset 0 -5rpx 8rpx rgba(21, 8, 3, 0.28),
    0 6rpx 12rpx rgba(13, 6, 3, 0.24);
}
.winder::after {
  content: "";
  position: absolute;
  inset: 14rpx;
  border-radius: 50%;
  background: rgba(43, 23, 14, 0.78);
  box-shadow: inset 0 2rpx 0 rgba(255, 237, 190, 0.18);
}

/* ---- 面板显示区（BPM + 拍号，位于梯形内部上方） ---- */
.metro-face {
  position: absolute;
  left: 50%; top: 40%;
  transform: translate(-50%, -50%);
  z-index: 4;
  display: flex; flex-direction: column; align-items: center; gap: 16rpx;
}
.bpm-display {
  display: flex; flex-direction: column; align-items: center;
}
.bpm-num {
  font-size: 88rpx;
  font-weight: 900;
  color: #eaf3ff;
  line-height: 1;
  text-shadow: 0 0 24rpx rgba(126, 216, 255, 0.42);
}
.bpm-label {
  font-size: 22rpx;
  color: rgba(218, 234, 255, 0.55);
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-top: 2rpx;
}
.meter-badge {
  padding: 6rpx 24rpx;
  border: 1rpx solid rgba(255, 231, 177, 0.32);
  border-radius: 999rpx;
  background: rgba(25, 13, 8, 0.20);
  color: rgba(255, 244, 214, 0.68);
  font-size: 22rpx;
  font-weight: 800;
  box-shadow: inset 0 1rpx 0 rgba(255, 250, 221, 0.10);
}

/* ---- 底座 ---- */
.metro-base {
  position: absolute;
  left: 50%; bottom: 32rpx;
  transform: translateX(-50%);
  width: 340rpx; height: 56rpx;
  z-index: 8;
  display: flex; align-items: center; justify-content: center;
}
.metro-base::before {
  content: "";
  width: 100%; height: 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(
    90deg,
    rgba(255, 230, 178, 0.10),
    rgba(255, 250, 240, 0.28) 50%,
    rgba(44, 21, 12, 0.10)
  );
}
.metro-base::after {
  content: "";
  position: absolute;
  bottom: -22rpx; left: 50%;
  transform: translateX(-50%);
  width: 96rpx; height: 14rpx;
  border-radius: 999rpx;
  background: rgba(29, 15, 10, 0.62);
  box-shadow: inset 0 4rpx 0 rgba(255, 242, 207, 0.06);
}

/* ========================================
   摆锤 — 轴心在底部（参照 web 版）
   ======================================== */

/* 摆杆容器：固定区域，旋转轴在底部 */
.pendulum-wrap {
  position: absolute;
  top: 110rpx;
  bottom: 95rpx;
  left: calc(50% - 10rpx);
  width: 20rpx;
  transform-origin: 50% 100%;
  z-index: 7;
}

/* 摆杆主体：继承底部旋转轴 */
.pendulum {
  position: absolute;
  inset: 0;
  transform-origin: 50% 100%;
}

/* 金属摆杆：从底部向上延伸（全高） */
.pendulum-rod {
  position: absolute;
  left: 50%;
  top: 0; bottom: 0;
  width: 8rpx;
  transform: translateX(-50%);
  border-radius: 999rpx;
  background: linear-gradient(90deg, #dbe8ff, #ffffff 48%, #c7d5ee);
  box-shadow:
    0 0 0 1rpx rgba(226, 239, 255, 0.32),
    4rpx 0 12rpx rgba(4, 8, 18, 0.22);
}

/* 配重块：位置由 JS 的 weightPosition 控制（距顶部百分比） */
.pendulum-weight {
  position: absolute;
  left: 50%;
  width: 76rpx; height: 42rpx;
  transform: translate(-50%, -50%);
  border-radius: 10rpx;
  background:
    radial-gradient(circle at 28% 22%, rgba(255, 213, 145, 0.72), transparent 22%),
    linear-gradient(145deg, #ff7f2a 0%, #ff4d24 58%, #bd2418 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 211, 153, 0.48),
    inset 0 -8rpx 0 rgba(126, 25, 12, 0.18),
    0 8rpx 14rpx rgba(13, 8, 18, 0.24);
}
.pendulum-weight::before {
  content: "";
  position: absolute;
  inset: 8rpx 13rpx;
  border-top: 3rpx solid rgba(255, 173, 100, 0.30);
  border-bottom: 3rpx solid rgba(154, 39, 22, 0.18);
}

/* 轴心帽：位于底部轴心处 */
.pivot-cap {
  position: absolute;
  bottom: 84rpx; left: 50%;
  transform: translate(-50%, 50%);
  width: 28rpx; height: 28rpx;
  border-radius: 50%;
  z-index: 9;
  background: radial-gradient(circle at 35% 32%, rgba(255,255,255,0.78), rgba(126,216,255,0.32));
  border: 2rpx solid rgba(126, 216, 255, 0.85);
  box-shadow:
    0 0 16rpx rgba(126, 216, 255, 0.40),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.45);
}

/* ========================================
   节拍指示区
   ======================================== */
.dots-row {
  display: flex; gap: 24rpx; justify-content: center;
  padding: 2rpx 0;
}
.dot {
  width: 52rpx; height: 52rpx; border-radius: 50%;
  background: rgba(255,255,255,0.07);
  transition: transform 0.08s ease-out, background 0.08s, box-shadow 0.08s;
}
.dot.accent {
  border: 3rpx solid rgba(255, 90, 50, 0.35);
}
.dot.mute {
  opacity: 0.15;
  background: rgba(255,255,255,0.02);
}
.dot.hit {
  background: var(--accent);
  transform: scale(1.30);
  box-shadow: 0 0 32rpx var(--accent-glow);
}
.dot.hit-accent {
  background: linear-gradient(145deg, #ff6b2b, #ff3920);
  transform: scale(1.35);
  box-shadow: 0 0 36rpx rgba(255, 70, 30, 0.45);
}

/* ========================================
   BPM 编辑弹层
   ======================================== */
.bpm-overlay {
  position: fixed; inset: 0; z-index: 200;
  background: rgba(0,0,0,0.58);
  display: flex; align-items: center; justify-content: center;
}
.bpm-card {
  width: 480rpx;
  padding: 48rpx 40rpx 36rpx;
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border-focus);
  display: flex; flex-direction: column; align-items: center; gap: 28rpx;
  box-shadow: 0 28rpx 80rpx rgba(0,0,0,0.55);
}
.bpm-card-title {
  font-size: 28rpx; font-weight: 700; color: var(--text-primary);
}
.bpm-card-input {
  width: 260rpx; height: 100rpx;
  text-align: center;
  font-size: 56rpx; font-weight: 700;
  color: var(--text-primary);
  background: rgba(255,255,255,0.08);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--border-focus);
}
.bpm-card-range {
  font-size: 24rpx; color: var(--text-tertiary);
}

/* ========================================
   微调控制
   ======================================== */
.bpm-tuner {
  width: 100%;
  display: flex; flex-direction: column; gap: 6rpx;
}
.tuner-steps {
  display: flex; gap: 10rpx;
}
.step-btn {
  flex: 1;
  height: 72rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: var(--radius-md);
  background: rgba(255,255,255,0.07);
  border: 1rpx solid var(--border);
  font-size: 28rpx; font-weight: 700;
  color: var(--text-secondary);
  min-height: 80rpx;
}
.bpm-slider { width: 100%; margin: 2rpx 0; }

/* ========================================
   传输栏
   ======================================== */
.transport {
  display: flex; gap: 16rpx; width: 100%; align-items: center;
  margin-top: 2rpx;
}
.trans-btn {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  border-radius: var(--radius-lg);
  min-height: 100rpx;
}
.tap-btn, .save-btn {
  flex: 0 0 160rpx;
  background: rgba(255,255,255,0.07);
  border: 1rpx solid var(--border);
  gap: 2rpx;
}
.trans-label {
  font-size: 30rpx; font-weight: 700; color: var(--text-secondary);
}
.tap-acc {
  font-size: 20rpx; color: var(--accent); font-weight: 600;
}
.play-btn {
  flex: 1;
  background: linear-gradient(145deg, #ff6b2b, #ff3920);
  color: #fff8f2;
  border: 0;
  box-shadow: 0 8rpx 24rpx rgba(255, 70, 30, 0.28);
}
.stop-btn {
  flex: 1;
  background: rgba(239,68,68,0.18);
  border: 1rpx solid rgba(239,68,68,0.30);
  box-shadow: none;
}
.play-symbol {
  font-size: 48rpx; color: #fff; font-weight: 700;
}

/* ========================================
   运行统计（始终显示）
   ======================================== */
.run-stats {
  width: 100%;
  display: flex; justify-content: space-around;
  padding: 16rpx 0;
  margin-top: 2rpx;
  margin-bottom: 16rpx;
  background: var(--surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border);
}
.stat {
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
}
.stat-num {
  font-size: 40rpx; font-weight: 700; color: var(--text-primary); line-height: 1;
}
.stat-num.muted {
  font-size: 26rpx; color: var(--text-tertiary); font-weight: 600;
}
.stat-cap {
  font-size: 22rpx; color: var(--text-tertiary); font-weight: 500;
}

/* 闪光覆盖 */
.flash-overlay {
  position: fixed; inset: 0;
  background: rgba(126,216,255,0.18);
  pointer-events: none; z-index: 999;
}

/* ========================================
   底部抽屉弹窗
   ======================================== */
.drawer-overlay {
  position: fixed; inset: 0; z-index: 300;
  background: rgba(0, 0, 0, 0);
  animation: fadeIn 0.28s ease-out forwards;
}
@keyframes fadeIn {
  to { background: rgba(0, 0, 0, 0.55); }
}

.drawer-sheet {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 88vh;
  background: #131d33;
  border-radius: 40rpx 40rpx 0 0;
  box-shadow: 0 -12rpx 60rpx rgba(0, 0, 0, 0.45);
  display: flex; flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
  animation: slideUp 0.32s cubic-bezier(0.32, 0.72, 0, 1) forwards;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

.drawer-handle {
  display: flex; justify-content: center;
  padding: 16rpx 0 8rpx;
  flex-shrink: 0;
}
.handle-bar {
  width: 64rpx; height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
}

.drawer-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8rpx 28rpx 20rpx;
  border-bottom: 1rpx solid var(--border);
  flex-shrink: 0;
}
.drawer-title {
  font-size: 32rpx; font-weight: 800;
  color: var(--text-primary);
}
.drawer-close {
  width: 52rpx; height: 52rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  font-size: 24rpx;
  color: var(--text-tertiary);
}
.drawer-close:active { background: rgba(255, 255, 255, 0.16); }

.drawer-body {
  flex: 1;
  height: 0;
  padding: 20rpx 0 0;
}
.drawer-spacer { height: 200rpx; }

/* ---- 设置卡片（抽屉内复用） ---- */
.set-card {
  padding: 24rpx;
  margin-left: 12rpx;
  margin-right: 12rpx;
  margin-bottom: 16rpx;
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border);
}
.set-card:last-child { margin-bottom: 0; }
.set-head {
  font-size: 26rpx; font-weight: 700; color: var(--text-primary);
  margin-bottom: 20rpx;
  display: flex; align-items: center; gap: 12rpx;
}
.set-head .hint {
  font-size: 22rpx; font-weight: 400; color: var(--text-tertiary);
  margin-left: auto;
}

.form-row {
  margin-bottom: 20rpx;
}
.form-row:last-child { margin-bottom: 0; }
.form-label {
  display: block;
  font-size: 22rpx; color: var(--text-tertiary);
  margin-bottom: 12rpx;
}

/* chip 选择行 */
.chip-row {
  display: flex; flex-wrap: wrap; gap: 12rpx;
}
.chip {
  padding: 10rpx 24rpx;
  border-radius: var(--radius-pill);
  background: rgba(255,255,255,0.06);
  border: 1rpx solid var(--border);
  font-size: 24rpx; font-weight: 600;
  color: var(--text-tertiary);
  transition: all 0.18s;
}
.chip.on {
  background: var(--accent-dim);
  border-color: var(--accent);
  color: var(--accent);
  box-shadow: 0 0 12rpx rgba(126,216,255,0.18);
}
.chip:active { opacity: 0.7; }

/* 重音按钮行 */
.accent-row {
  display: flex; gap: 12rpx; flex-wrap: wrap;
}
.accent-btn {
  width: 80rpx; height: 80rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: var(--radius-md);
  background: rgba(255,255,255,0.06);
  border: 2rpx solid var(--border);
  font-size: 28rpx; font-weight: 700;
  color: var(--text-tertiary);
  transition: all 0.18s;
}
.accent-btn.accent {
  background: rgba(255, 84, 42, 0.18);
  border-color: rgba(255, 84, 42, 0.55);
  color: #ff6b4a;
  box-shadow: 0 0 16rpx rgba(255, 70, 30, 0.22);
}
.accent-btn.normal {
  background: rgba(126,216,255,0.12);
  border-color: rgba(126,216,255,0.35);
  color: var(--accent);
}
.accent-btn.mute {
  background: transparent;
  border-style: dashed;
  color: var(--text-disabled);
  opacity: 0.5;
}

/* 重音图例 */
.legend {
  display: flex; gap: 24rpx; margin-top: 16rpx;
  font-size: 20rpx; color: var(--text-tertiary);
}
.legend text {
  display: flex; align-items: center; gap: 6rpx;
}
.leg-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
}
.leg-dot.a { background: rgba(255, 84, 42, 0.55); }
.leg-dot.n { background: rgba(126,216,255,0.45); }
.leg-dot.m {
  background: transparent;
  border: 2rpx dashed var(--text-disabled);
}

/* 音符芯片/图标已移至全局 app.wxss */
